{
  "name": "obsidian-jwpub-plugin",
  "version": "1.0.0",
  "description": "A plugin for Obsidian to interact with JW publications",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "jwpub"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.5",
    "tslib": "^2.8.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "jsdom": "^21.1.0",
    "obsidian": "^1.4.11"
  }
}
